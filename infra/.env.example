ENV=development
DEBUG=true

POSTGRES_USER=audioplatform
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=audio_platform

REDIS_URL=redis://redis:6379/0

RABBITMQ_DEFAULT_USER=audioplatform
RABBITMQ_DEFAULT_PASS=change_me_rabbitmq_password
RABBITMQ_URL=amqp://audioplatform:change_me_rabbitmq_password@rabbitmq:5672//

MINIO_ROOT_USER=audioplatform
MINIO_ROOT_PASSWORD=change_me_minio_root_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=audioplatform
MINIO_SECRET_KEY=change_me_minio_root_password
MINIO_BUCKET=audio-tracks
MINIO_SECURE=false

DATABASE_URL=postgresql://audioplatform:change_me_postgres_password@postgres:5432/audio_platform

SECRET_KEY=change_me_application_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
MAX_FILE_SIZE=536870912
MAX_COVER_IMAGE_SIZE=5242880

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080","https://resonance-sound.ru","https://www.resonance-sound.ru"]

VITE_API_URL=/api/v1

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_password
